{
  "name": "multi-transfer-balance-assert",
  "steps": [
    {
      "type": "log",
      "message": "Multi transfer scenario starts."
    },
    {
      "type": "assert_usdb_state",
      "height": "$effective_target_height",
      "expected_total_balance": 0,
      "expected_active_count": 0
    },
    {
      "type": "send_and_confirm",
      "amount_btc": "$send_amount_btc",
      "mine_blocks": 1,
      "var": "tx1"
    },
    {
      "type": "assert_balance_history_balance",
      "script_hash": "$tx1.script_hash",
      "height": "$tx1.confirmed_height",
      "expected_sat": "$tx1.amount_sat"
    },
    {
      "type": "send_and_confirm",
      "amount_btc": "0.15",
      "mine_blocks": 1,
      "var": "tx2"
    },
    {
      "type": "assert_balance_history_balance",
      "script_hash": "$tx2.script_hash",
      "height": "$tx2.confirmed_height",
      "expected_sat": "$tx2.amount_sat"
    },
    {
      "type": "assert_eq",
      "left": "$tx2.mine_blocks",
      "right": 1,
      "message": "Second transfer should confirm with exactly one mined block"
    },
    {
      "type": "assert_usdb_state",
      "height": "$tx2.confirmed_height",
      "expected_total_balance": 0,
      "expected_active_count": 0
    }
  ]
}

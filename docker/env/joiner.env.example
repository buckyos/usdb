# Copy this file to docker/local/joiner/env/joiner.env and adjust the values for your node.

USDB_SERVICES_IMAGE=usdb-services:local
ORD_IMAGE=usdb-world-sim-tools:local
ETHW_IMAGE=usdb-ethw:local

# Set the actual geth/geth-derived launch command provided by your ETHW image.
ETHW_COMMAND=geth --datadir /data/ethw --http --http.addr 0.0.0.0 --http.vhosts=* --ws --ws.addr 0.0.0.0 --ws.origins=*
ETHW_RPC_URL=http://ethw-node:8545

# Recommended default: run bitcoind locally in Docker and use cookie auth.
BTC_NETWORK=bitcoin
BTC_RPC_URL=http://btc-node:8332
BTC_NODE_DATA_DIR=/home/bitcoin/.bitcoin
BTC_DATA_DIR=/data/bitcoind
BTC_AUTH_MODE=cookie
BTC_COOKIE_FILE=/data/bitcoind/.cookie
BTC_RPC_USER=
BTC_RPC_PASSWORD=

BH_ROOT_DIR=/data/balance-history
BH_RPC_PORT=28010
BH_SNAPSHOT_TRUST_MODE=dev
BH_SNAPSHOT_SIGNING_KEY_FILE=
BH_SNAPSHOT_TRUSTED_KEYS_FILE=/run/usdb/keys/trusted_snapshot_keys.json

USDB_INDEXER_ROOT_DIR=/data/usdb-indexer
USDB_INDEXER_RPC_PORT=28020
USDB_GENESIS_BLOCK_HEIGHT=900000
INSCRIPTION_SOURCE=bitcoind

CONTROL_PLANE_ROOT_DIR=/data/usdb-control-plane
CONTROL_PLANE_PORT=28040
CONTROL_PLANE_BIND_PORT=28040

ORD_DATA_DIR=/data/ord
ORD_SERVER_PORT=28030
ORD_SERVER_BIND_PORT=28030

SNAPSHOT_MODE=none
BH_SNAPSHOT_FILE=
BH_SNAPSHOT_MANIFEST=
SNAPSHOT_HOST_DIR=./local/joiner/snapshots
SNAPSHOT_KEYS_HOST_DIR=./local/joiner/keys

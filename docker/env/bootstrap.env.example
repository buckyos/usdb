# Copy this file to docker/local/bootstrap/env/bootstrap.env for cold-start flows.

USDB_SERVICES_IMAGE=usdb-services:local
ORD_IMAGE=usdb-world-sim-tools:local
ETHW_IMAGE=usdb-ethw:local
USDB_DOCKER_SCRIPTS_HOST_DIR=./scripts

# The ETHW container should consume the prepared bootstrap artifacts from /bootstrap.
# Example only; replace this with the actual startup command provided by your image.
ETHW_COMMAND=geth --datadir /data/ethw --http --http.addr 0.0.0.0 --http.vhosts=* --ws --ws.addr 0.0.0.0 --ws.origins=* --mine --miner.threads=1 --miner.etherbase 0x1111111111111111111111111111111111111111
ETHW_INIT_COMMAND=geth --datadir /data/ethw init /bootstrap/ethw-genesis.json
ETHW_DATA_DIR=/data/ethw
ETHW_RPC_URL=http://ethw-node:8545

BTC_NETWORK=bitcoin
BTC_RPC_URL=http://btc-node:8332
BTC_NODE_DATA_DIR=/home/bitcoin/.bitcoin
BTC_DATA_DIR=/data/bitcoind
BTC_AUTH_MODE=cookie
BTC_COOKIE_FILE=/data/bitcoind/.cookie

BH_ROOT_DIR=/data/balance-history
BH_RPC_PORT=28010
BH_SNAPSHOT_TRUST_MODE=dev
BH_SNAPSHOT_SIGNING_KEY_FILE=
BH_SNAPSHOT_TRUSTED_KEYS_FILE=/run/usdb/keys/trusted_snapshot_keys.json

USDB_INDEXER_ROOT_DIR=/data/usdb-indexer
USDB_INDEXER_RPC_PORT=28020
USDB_GENESIS_BLOCK_HEIGHT=900000
INSCRIPTION_SOURCE=bitcoind

CONTROL_PLANE_ROOT_DIR=/data/usdb-control-plane
CONTROL_PLANE_PORT=28040
CONTROL_PLANE_BIND_PORT=28040

ORD_DATA_DIR=/data/ord
ORD_SERVER_PORT=28030
ORD_SERVER_BIND_PORT=28030

BOOTSTRAP_DIR=/bootstrap
BOOTSTRAP_REQUIRE_ETHW_GENESIS=true
ETHW_BOOTSTRAP_TRUST_MODE=manifest
BOOTSTRAP_HOST_DIR=./local/bootstrap/manifests
BOOTSTRAP_KEYS_HOST_DIR=./local/bootstrap/keys
ETHW_BOOTSTRAP_GENESIS_INPUT_FILE=/bootstrap-input/ethw-genesis.json
ETHW_BOOTSTRAP_GENESIS_MANIFEST_INPUT_FILE=/bootstrap-input/ethw-genesis.manifest.json
ETHW_BOOTSTRAP_GENESIS_SIG_INPUT_FILE=
ETHW_BOOTSTRAP_TRUSTED_KEYS_INPUT_FILE=
ETHW_BOOTSTRAP_CONFIG_INPUT_FILE=
SOURCE_DAO_CONFIG_INPUT_FILE=/bootstrap-input/sourcedao-bootstrap-config.json
ETHW_CANONICAL_GENESIS_FILE=/bootstrap/ethw-genesis.json
ETHW_CANONICAL_GENESIS_MANIFEST_FILE=/bootstrap/ethw-genesis.manifest.json
ETHW_CANONICAL_GENESIS_SIG_FILE=/bootstrap/ethw-genesis.manifest.sig
ETHW_CANONICAL_TRUSTED_KEYS_FILE=/bootstrap/trusted-ethw-genesis-keys.json

SOURCE_DAO_BOOTSTRAP_MODE=disabled
SOURCE_DAO_BOOTSTRAP_SCOPE=dao-dividend-only
SOURCE_DAO_BOOTSTRAP_PREPARE=validate
SOURCE_DAO_BOOTSTRAP_IMAGE=node:22-bookworm
SOURCE_DAO_REPO_HOST_DIR=../../SourceDAO
SOURCE_DAO_REPO_DIR=/workspace/SourceDAO
SOURCE_DAO_ARTIFACTS_DIR=/workspace/SourceDAO/artifacts-usdb
SOURCE_DAO_BOOTSTRAP_CONFIG_FILE=/bootstrap/sourcedao-bootstrap-config.json
SOURCE_DAO_BOOTSTRAP_STATE_FILE=/bootstrap/sourcedao-bootstrap-state.json
SOURCE_DAO_BOOTSTRAP_MARKER_FILE=/bootstrap/sourcedao-bootstrap.done.json
SOURCE_DAO_BOOTSTRAP_LOG_FILE=/bootstrap/sourcedao-bootstrap.log
SOURCE_DAO_RPC_WAIT_SECONDS=300

SNAPSHOT_MODE=none
BH_SNAPSHOT_FILE=
BH_SNAPSHOT_MANIFEST=
SNAPSHOT_HOST_DIR=./local/bootstrap/snapshots
SNAPSHOT_KEYS_HOST_DIR=./local/bootstrap/keys

# Copy this file to docker/local/bootstrap/env/bootstrap.env for cold-start flows.

USDB_SERVICES_IMAGE=usdb-services:local
ETHW_IMAGE=usdb-ethw:local

# The ETHW container should consume the prepared bootstrap artifacts from /bootstrap.
# Example only; replace this with the actual startup command provided by your image.
ETHW_COMMAND=geth --datadir /data/ethw --http --http.addr 0.0.0.0 --ws --ws.addr 0.0.0.0

BTC_NETWORK=bitcoin
BTC_RPC_URL=http://btc-node:8332
BTC_DATA_DIR=/data/bitcoind
BTC_AUTH_MODE=cookie

BH_ROOT_DIR=/data/balance-history
BH_RPC_PORT=28010
BH_SNAPSHOT_TRUST_MODE=dev
BH_SNAPSHOT_SIGNING_KEY_FILE=
BH_SNAPSHOT_TRUSTED_KEYS_FILE=/run/usdb/keys/trusted_snapshot_keys.json

USDB_INDEXER_ROOT_DIR=/data/usdb-indexer
USDB_INDEXER_RPC_PORT=28020
USDB_GENESIS_BLOCK_HEIGHT=900000
INSCRIPTION_SOURCE=bitcoind

BOOTSTRAP_DIR=/bootstrap
BOOTSTRAP_REQUIRE_ETHW_GENESIS=true
BOOTSTRAP_HOST_DIR=./docker/local/bootstrap/manifests
ETHW_BOOTSTRAP_GENESIS_FILE=/bootstrap-input/ethw-genesis.json
ETHW_BOOTSTRAP_CONFIG_FILE=
SOURCE_DAO_CONFIG_FILE=

SNAPSHOT_MODE=none
BH_SNAPSHOT_FILE=
BH_SNAPSHOT_MANIFEST=
SNAPSHOT_HOST_DIR=./docker/local/bootstrap/snapshots
SNAPSHOT_KEYS_HOST_DIR=./docker/local/bootstrap/keys

# Copy this file to docker/local/world-sim/env/world-sim.env for the optional
# world-sim overlay.
#
# This file intentionally stays separate from dev-sim so the default local
# development stack is not changed.

USDB_SERVICES_IMAGE=usdb-services:local
WORLD_SIM_BITCOIN_IMAGE=usdb-bitcoin28-regtest:local
WORLD_SIM_TOOLS_IMAGE=usdb-world-sim-tools:local
ORD_IMAGE=usdb-world-sim-tools:local
ETHW_IMAGE=usdb-ethw:local
USDB_DOCKER_NETWORK=usdb-world-sim-net

ETHW_COMMAND=geth --datadir /data/ethw --http --http.addr 0.0.0.0 --http.vhosts=* --http.api eth,net,web3,txpool,miner --ws --ws.addr 0.0.0.0 --ws.origins=* --ws.api eth,net,web3,txpool --mine --miner.threads=1
ETHW_RPC_URL=http://ethw-node:8545
ETHW_IDENTITY_MODE=deterministic-seed
ETHW_IDENTITY_SEED=
ETHW_MINER_ADDRESS=
ETHW_MINER_PRIVATE_KEY_HEX=
ETHW_AUTO_APPEND_MINER_ETHERBASE=1
ETHW_IDENTITY_MARKER=/data/ethw/bootstrap/ethw-sim-identity.json
ETHW_IDENTITY_MARKER_WAIT_SECS=60
ETHW_MINER_AGENT_ID=0
# ETHW_SIM_PROTOCOL_ALIGNMENT is set automatically by the local world-sim tools:
# - run_local_world_sim.sh      -> 0
# - run_local_world_sim_ethw.sh -> 1
ETHW_SIM_PROTOCOL_ALIGNMENT=0

BTC_NETWORK=regtest
BTC_RPC_URL=http://btc-node:28132
BTC_RPC_PORT=28132
BTC_P2P_PORT=28133
BTC_NODE_DATA_DIR=/home/bitcoin/.bitcoin
BTC_DATA_DIR=/data/bitcoind
BTC_AUTH_MODE=userpass
BTC_RPC_USER=usdb
BTC_RPC_PASSWORD=usdb-dev-sim
BTC_COOKIE_FILE=/data/bitcoind/regtest/.cookie

BH_ROOT_DIR=/data/balance-history
BH_RPC_PORT=28110
BH_SNAPSHOT_TRUST_MODE=dev

USDB_INDEXER_ROOT_DIR=/data/usdb-indexer
USDB_INDEXER_RPC_PORT=28120
USDB_GENESIS_BLOCK_HEIGHT=1
INSCRIPTION_SOURCE=bitcoind

CONTROL_PLANE_ROOT_DIR=/data/usdb-control-plane
CONTROL_PLANE_PORT=28140
CONTROL_PLANE_BIND_PORT=28140
CONTROL_PLANE_SOURCEDAO_WEB_URL=http://127.0.0.1:3050

SNAPSHOT_MODE=none
BH_SNAPSHOT_FILE=
BH_SNAPSHOT_MANIFEST=
SNAPSHOT_HOST_DIR=./local/dev-sim/snapshots
SNAPSHOT_KEYS_HOST_DIR=./local/dev-sim/keys

# Build the release images once before running the overlay:
#   docker/scripts/tools/run_local_world_sim.sh build-images
#
# The build helper packages local host binaries into:
# - WORLD_SIM_BITCOIN_IMAGE
# - WORLD_SIM_TOOLS_IMAGE
#
# ord packaging supports two modes:
# - WORLD_SIM_RELEASE_ORD_SOURCE=git-tag
#   Build ord from a fixed official git tag inside Docker.
# - WORLD_SIM_RELEASE_ORD_SOURCE=local
#   Package a locally built ord binary from WORLD_SIM_RELEASE_ORD_BIN_HOST_PATH.
#
# Recommended for formal image builds:
#   WORLD_SIM_RELEASE_ORD_SOURCE=git-tag
#   WORLD_SIM_RELEASE_ORD_VERSION=0.23.3
#
# Optional overrides for docker/scripts/tools/build_world_sim_images.sh:
# WORLD_SIM_RELEASE_ORD_SOURCE=git-tag
# WORLD_SIM_RELEASE_ORD_VERSION=0.23.3
# WORLD_SIM_RELEASE_ORD_BIN_HOST_PATH=/home/bucky/ord/target/release/ord
#
# Runtime state is preserved in Docker volumes unless you explicitly run:
#   docker/scripts/tools/run_local_world_sim.sh reset
#
# WORLD_SIM_STATE_MODE controls startup semantics:
# - persistent   keep existing volumes and resume the current world
# - reset        clear volumes before startup
# - seeded-reset clear volumes before startup and deterministically recreate
#                ord wallet identities from WORLD_SIM_IDENTITY_SEED

ORD_DATA_DIR=/data/ord
ORD_SERVER_PORT=28130
ORD_SERVER_BIND_PORT=28130

WORLD_SIM_WORK_DIR=/data/world-sim
WORLD_SIM_STATE_MODE=persistent
WORLD_SIM_IDENTITY_SEED=
WORLD_SIM_RECOVERY_STATE_FILE=/data/world-sim/bootstrap/world-sim-recovery-state.json
WORLD_SIM_ORD_STABILITY_PROBES=2
WORLD_SIM_ORD_STABILITY_SLEEP_SECS=1
MINER_WALLET_NAME=usdb-world-miner
ORD_WALLET_PREFIX=usdb-world-agent
AGENT_COUNT=5
PREMINE_BLOCKS=140
FUND_AGENT_AMOUNT_BTC=4.0
FUND_CONFIRM_BLOCKS=2
SYNC_TIMEOUT_SEC=300

# SIM_BLOCKS > 0 runs a bounded one-shot batch and exits successfully.
# SIM_BLOCKS=0 keeps the simulator in continuous mode, using
# SIM_LOOP_BATCH_BLOCKS sized batches until the container is stopped.
SIM_BLOCKS=0
SIM_LOOP_BATCH_BLOCKS=25
SIM_SEED=42
SIM_FEE_RATE=1
SIM_MAX_ACTIONS_PER_BLOCK=2
SIM_MINT_PROBABILITY=0.20
SIM_INVALID_MINT_PROBABILITY=0.02
SIM_TRANSFER_PROBABILITY=0.20
SIM_REMINT_PROBABILITY=0.10
SIM_SEND_PROBABILITY=0.30
SIM_SPEND_PROBABILITY=0.15
SIM_SLEEP_MS_BETWEEN_BLOCKS=300
SIM_FAIL_FAST=0
SIM_INITIAL_ACTIVE_AGENTS=3
SIM_AGENT_GROWTH_INTERVAL_BLOCKS=30
SIM_AGENT_GROWTH_STEP=1
SIM_POLICY_MODE=adaptive
SIM_SCRIPTED_CYCLE=mint,send_balance,transfer,remint,spend_balance,noop
SIM_REPORT_ENABLED=1
SIM_REPORT_FLUSH_EVERY=1
SIM_AGENT_SELF_CHECK_ENABLED=1
SIM_AGENT_SELF_CHECK_INTERVAL_BLOCKS=1
SIM_AGENT_SELF_CHECK_SAMPLE_SIZE=0
SIM_GLOBAL_CROSS_CHECK_ENABLED=1
SIM_GLOBAL_CROSS_CHECK_INTERVAL_BLOCKS=20
SIM_GLOBAL_CROSS_CHECK_LEADERBOARD_TOP_N=20
SIM_GLOBAL_CROSS_CHECK_OWNER_SAMPLE_SIZE=16
SIM_VALIDATOR_SAMPLE_ENABLED=0
SIM_VALIDATOR_SAMPLE_MODE=single
SIM_VALIDATOR_SAMPLE_TAMPER_ENABLED=0
SIM_VALIDATOR_SAMPLE_INTERVAL_BLOCKS=0
SIM_VALIDATOR_SAMPLE_SIZE=1
SIM_VALIDATOR_SAMPLE_MIN_HEAD_ADVANCE=2
SIM_REORG_INTERVAL_BLOCKS=0
SIM_REORG_DEPTH=3
SIM_REORG_MAX_EVENTS=1

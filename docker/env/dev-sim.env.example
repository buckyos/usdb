# Copy this file to docker/env/dev-sim.env for single-machine local simulation.

USDB_SERVICES_IMAGE=usdb-services:local
ETHW_IMAGE=usdb-ethw:local

ETHW_COMMAND=geth --datadir /data/ethw --http --http.addr 0.0.0.0 --ws --ws.addr 0.0.0.0

BTC_NETWORK=regtest
BTC_RPC_URL=http://btc-node:28132
BTC_DATA_DIR=/data/bitcoind
BTC_AUTH_MODE=cookie

BH_ROOT_DIR=/data/balance-history
BH_RPC_PORT=28110
BH_SNAPSHOT_TRUST_MODE=dev

USDB_INDEXER_ROOT_DIR=/data/usdb-indexer
USDB_INDEXER_RPC_PORT=28120
USDB_GENESIS_BLOCK_HEIGHT=1
INSCRIPTION_SOURCE=bitcoind

SNAPSHOT_MODE=none
BH_SNAPSHOT_FILE=
BH_SNAPSHOT_MANIFEST=
SNAPSHOT_HOST_DIR=./docker/local/dev-sim/snapshots
SNAPSHOT_KEYS_HOST_DIR=./docker/local/dev-sim/keys

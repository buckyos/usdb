FROM rust:1.89.0-bookworm AS ord-builder

ARG ORD_BUILD_MODE=staged-binary
ARG ORD_VERSION=0.23.3

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        git \
        pkg-config \
        libssl-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /tmp
COPY docker/.build-world-sim/ord/bin/ord /tmp/staged-ord/ord

RUN mkdir -p /opt/ord/bin \
    && case "${ORD_BUILD_MODE}" in \
      staged-binary) \
        install -m 0755 /tmp/staged-ord/ord /opt/ord/bin/ord \
        ;; \
      git-tag) \
        git clone --branch "${ORD_VERSION}" --depth 1 https://github.com/ordinals/ord.git /tmp/ord-src \
        && cd /tmp/ord-src \
        && cargo build --bin ord --release \
        && install -m 0755 /tmp/ord-src/target/release/ord /opt/ord/bin/ord \
        ;; \
      *) \
        echo "Unsupported ORD_BUILD_MODE: ${ORD_BUILD_MODE}" >&2 \
        && exit 1 \
        ;; \
    esac

FROM python:3.12-bookworm

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        bash \
        ca-certificates \
        curl \
        jq \
        procps \
        tini \
    && mkdir -p /opt/usdb/docker/scripts/entrypoints /opt/usdb/docker/scripts/helpers \
    && rm -rf /var/lib/apt/lists/*

COPY docker/scripts/entrypoints/start_ord_server.sh /opt/usdb/docker/scripts/entrypoints/start_ord_server.sh
COPY docker/scripts/entrypoints/start_world_sim_bitcoind.sh /opt/usdb/docker/scripts/entrypoints/start_world_sim_bitcoind.sh
COPY docker/scripts/entrypoints/start_world_sim.sh /opt/usdb/docker/scripts/entrypoints/start_world_sim.sh
COPY docker/scripts/helpers/wait_for_tcp.sh /opt/usdb/docker/scripts/helpers/wait_for_tcp.sh
COPY docker/.build-world-sim/bitcoin/bin/bitcoin-cli /opt/bitcoin/bin/bitcoin-cli
COPY --from=ord-builder /opt/ord/bin/ord /opt/ord/bin/ord
COPY src/btc/usdb-indexer/scripts/regtest_world_simulator.py /opt/usdb/world-sim/regtest_world_simulator.py
COPY docker/world-sim/bip39-english.txt /opt/usdb/world-sim/bip39-english.txt

RUN chmod +x /opt/usdb/docker/scripts/entrypoints/start_ord_server.sh \
    /opt/usdb/docker/scripts/entrypoints/start_world_sim_bitcoind.sh \
    /opt/usdb/docker/scripts/entrypoints/start_world_sim.sh \
    /opt/usdb/docker/scripts/helpers/wait_for_tcp.sh \
    /opt/bitcoin/bin/bitcoin-cli \
    /opt/ord/bin/ord

ENTRYPOINT ["/usr/bin/tini", "--"]
CMD ["bash"]
